# Environment configuration
NODE_ENV=development

# ---------------------------------------------------------------------------
# Tenant identity (required when testing a specific tenant locally).
# These are read by config/tenant.js and surfaced via GET /api/tenant.
# Match these to one of config/tenants/<slug>/ — pick mbao, keur-massar, or
# sacre-coeur, or generate a new one with `npm run tenant:create`.
# ---------------------------------------------------------------------------
TENANT_SLUG=mbao
TENANT_NAME=Mbao
TENANT_BRAND_KEY=MBAO

# Session secret — random in production, anything for dev
SESSION_SECRET=dev-only-do-not-use-in-prod

# Database configuration — point at a LOCAL Postgres (not Mata production).
# Use a fresh DB per tenant for clean testing, e.g. ventes_mbao_dev.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=bonea2024
DB_NAME=ventes_mbao_dev
DB_SSL=false

# Optional integrations — leave blank for tenant testing unless you need them
BICTORYS_API_KEY=
BICTORYS_BASE_URL=https://api.bictorys.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Centre de découpe Mata — forward des commandes POS vers la table
# commandes_decoupe côté Mata. Laisse les URL/clé vides pour désactiver
# l'intégration (l'endpoint /api/decoupe/send retourne 503 avec un message
# clair).
#
# MATA_DECOUPE_CENTRE accepte une LISTE séparée par ';' — chaque entrée
# devient une option dans le select du modal POS. La 1ère entrée sert
# de défaut. Exemple typique multi-centres:
#   MATA_DECOUPE_CENTRE=Centre de Découpe Banlieue;Centre de Découpe Dakar
# Pour un seul centre, ne mets pas de ';'.
MATA_DECOUPE_BASE_URL=
MATA_DECOUPE_API_KEY=
MATA_DECOUPE_CENTRE=Centre de Découpe Banlieue;Centre de Découpe Dakar

# Mata Dépenses Management (MataBanq) — source officielle des créances
# fournisseur viande. L'UI Finance > Créances fetch
# GET /external/api/creance?dateDebut=&dateFin=&label=<Maas Mbao|...>
# avec le label dérivé de brand-config.json (finance_label, sinon
# "Maas <nom_complet>"). Si DEPENSES_API_BASE_URL ou DEPENSES_API_KEY est
# vide, le bloc "Créance CDB" reste masqué côté UI; le calcul Maas local
# (commission 3% + marge Centre de Découpe) reste affiché.
DEPENSES_API_BASE_URL=
DEPENSES_API_KEY=
