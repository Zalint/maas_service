# Environment configuration
NODE_ENV=development

# ---------------------------------------------------------------------------
# Tenant identity (required when testing a specific tenant locally).
# These are read by config/tenant.js and surfaced via GET /api/tenant.
# Match these to one of config/tenants/<slug>/ — pick mbao, keur-massar, or
# sacre-coeur, or generate a new one with `npm run tenant:create`.
# ---------------------------------------------------------------------------
TENANT_SLUG=mbao
TENANT_NAME=Mbao
TENANT_BRAND_KEY=MBAO

# Session secret — random in production, anything for dev
SESSION_SECRET=dev-only-do-not-use-in-prod

# Database configuration — point at a LOCAL Postgres (not Mata production).
# Use a fresh DB per tenant for clean testing, e.g. ventes_mbao_dev.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=bonea2024
DB_NAME=ventes_mbao_dev
DB_SSL=false

# Optional integrations — leave blank for tenant testing unless you need them
BICTORYS_API_KEY=
BICTORYS_BASE_URL=https://api.bictorys.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Centre de découpe Mata — forward des commandes POS vers la table
# commandes_decoupe côté Mata. Laisse vide pour désactiver l'option (la
# checkbox "Envoyer au centre de découpe" tombera sur 503 avec un message
# clair). MATA_DECOUPE_CENTRE varie par tenant: typiquement
# "Centre de Découpe Banlieue" pour mbao/keur-massar, "Centre de Découpe
# Dakar" pour sacre-coeur.
MATA_DECOUPE_BASE_URL=
MATA_DECOUPE_API_KEY=
MATA_DECOUPE_CENTRE=Centre de découpe
