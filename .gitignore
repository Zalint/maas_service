# Dépendances
node_modules/
package-lock.json

# Fichiers de configuration locale
.env
.env.local
.env.example
config.json

# Per-tenant secret bundles — generated locally by `npm run tenant:create`,
# pasted into Render dashboard, NEVER committed (contain SESSION_SECRET
# and EXTERNAL_API_KEY).
config/tenants/*/.env.tenant

# Fichiers de données
*.csv
*.xlsx
*.xls

# Scripts SQL temporaires et modèles de développement
create-weight-params-table.sql
db/models/PointVente.js

# Fichiers système
.DS_Store
Thumbs.db

# Fichiers d'IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Fichiers de build
dist/
build/

# Fichiers SSH
mata
mata.pub
sal.txt

# Scripts de base de données (contiennent des credentials de production)
copy-prod-db*.ps1
copy-prod-db*.sh
copy-prod-db*.js
scripts/dump-prod-*.js
update-preprod-db.bat
DATABASE_COPY_README.md
db_backups/
temp_db_dumps/

# Test files (contain API keys or sensitive data)
test-*.js
check-*.js
debug-*.js
FINAL-TEST-*.js
test-*.json
api-performance-achat-*.json

# Local startup scripts (peuvent contenir des secrets/API keys)
start_matix.ps1
start_maas_*.ps1

# Postgres local control scripts (chemins specifiques a la machine)
start_postgres.ps1
stop_postgres.ps1

# Artefacts du simulateur RawBT (scripts/test-ticket-qr*.js)
ticket-sample.bin
qr-*.png
