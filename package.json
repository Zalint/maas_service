{
  "name": "gestion-ventes",
  "version": "1.0.0",
  "description": "Application de gestion des ventes",
  "main": "script.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:local": "jest local_tests",
    "pretest": "jest tests local_tests",
    "start": "node server.js",
    "prebuild": "npm install axios --no-save",
    "prestart:test": "jest --testPathIgnorePatterns=\"auth.test.js|auth.integration.test.js|reconciliation.integration.test.js\"",
    "start:test": "npm run prestart:test && node -r dotenv/config server.js",
    "dev": "nodemon -r dotenv/config server.js",
    "download-deepseek": "node download-deepseek.js",
    "migrate": "node -r dotenv/config migrate.js",
    "db:create": "node -r dotenv/config -e \"require('./db/models').syncDatabase(true)\"",
    "db:reset": "node -r dotenv/config -e \"require('./db/models').syncDatabase(true)\"",
    "db:view": "node -r dotenv/config view-db.js",
    "db:schema": "node -r dotenv/config db-schema.js",
    "db:export": "node -r dotenv/config export-db.js",
    "db:explore": "node -r dotenv/config explore-db.js",
    "db:migrate:sqlite-to-postgres": "node -r dotenv/config scripts/migrate-sqlite-to-postgres.js",
    "db:update-schema": "node -r dotenv/config db/update-schema.js",
    "db:migrate-config": "node -r dotenv/config scripts/migrate-config-to-db.js",
    "db:migrate-config:force": "node -r dotenv/config scripts/migrate-config-to-db.js --force",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:reconciliation": "cypress run --spec 'cypress/e2e/reconciliation.cy.js'",
    "test:unit": "jest --testPathPattern='tests/.*\\.test\\.js' --testPathIgnorePatterns=\"auth.test.js|auth.integration.test.js|reconciliation.integration.test.js\"",
    "test:analytics": "jest tests/analytics.test.js --verbose",
    "test:analytics:watch": "jest tests/analytics.test.js --watch",
    "test:e2e": "npm run cy:run",
    "test:all": "npm run test:unit && npm run test:e2e",
    "postinstall": "echo 'Installed packages:' && npm list --depth=0",
    "stock:copy": "node scripts/copy-stock-cron.js",
    "stock:copy:dry-run": "node scripts/copy-stock-cron.js --dry-run",
    "stock:copy:test": "node scripts/test-copy-stock.js",
    "stock:copy:create-test": "node scripts/test-copy-stock.js --create-test-data",
    "stock:copy:clean-test": "node scripts/test-copy-stock.js --clean-test-data",
    "tenant:apply": "node scripts/apply-tenant-config.js",
    "tenant:create": "node scripts/setup-tenant.js",
    "tenant:init": "node scripts/init-tenant-db.js",
    "tenant:verify": "node scripts/verify-tenant.js",
    "tenant:dev": "node scripts/dev-tenant.js",
    "tenant:migrate": "node scripts/migrate-tenant-to-shared.js",
    "tenant:drop": "node scripts/drop-tenant-schema.js",
    "tenant:rename-abattage": "node scripts/rename-abattage-to-depot.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "csv-parser": "^3.0.0",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "ml-regression-simple-linear": "^2.0.5",
    "natural": "^6.12.0",
    "openai": "^6.8.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "rss-parser": "^3.13.0",
    "sequelize": "^6.37.1",
    "sqlite3": "^5.1.7",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "cypress": "^12.17.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "node-fetch": "^2.7.0",
    "nodemon": "^2.0.22",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": "20.x"
  }
}
